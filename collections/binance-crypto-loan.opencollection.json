              },
              {
                "name": "loanAmount",
                "value": "",
                "type": "query"
              },
              {
                "name": "collateralCoin",
                "value": "",
                "type": "query"
              },
              {
                "name": "collateralAmount",
                "value": "",
                "type": "query"
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
