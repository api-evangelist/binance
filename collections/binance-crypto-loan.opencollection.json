              },
              {
                "name": "collateralReturn",
                "value": "",
                "type": "query"
              },
              {
                "name": "fullRepayment",
                "value": "",
                "type": "query"
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
