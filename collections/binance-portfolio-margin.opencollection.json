{
  "opencollection": "1.0.0",
  "info": {
    "name": "Binance Portfolio Margin API",
    "version": "1"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "X-MBX-APIKEY",
      "value": "{{X-MBX-APIKEY}}",
      "placement": "header"
