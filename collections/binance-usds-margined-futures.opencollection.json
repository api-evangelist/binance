      "items": [
        {
          "info": {
            "name": "Test connectivity",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://fapi.binance.com/fapi/v1/ping"
          },
          "docs": "Test connectivity to the futures REST API."
        },
        {
          "info": {
            "name": "Check server time",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://fapi.binance.com/fapi/v1/time"
          },
          "docs": "Test connectivity and get the current server time."
