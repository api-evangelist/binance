    {
      "info": {
        "name": "User Data Stream",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Start user data stream",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://fapi.binance.com/fapi/v1/listenKey",
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Start a new user data stream for futures. Returns a listen key that can be used to subscribe to user data WebSocket streams."
