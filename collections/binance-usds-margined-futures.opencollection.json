        {
          "info": {
            "name": "Keepalive user data stream",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://fapi.binance.com/fapi/v1/listenKey",
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Keepalive a user data stream to prevent timeout."
        },
