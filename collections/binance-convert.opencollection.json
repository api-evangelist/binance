{
  "opencollection": "1.0.0",
  "info": {
    "name": "Binance Convert API",
    "version": "1"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "X-MBX-APIKEY",
      "value": "{{X-MBX-APIKEY}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Convert",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List all convert pairs",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.binance.com/sapi/v1/convert/exchangeInfo",
            "params": [
              {
                "name": "fromAsset",
                "value": "",
                "type": "query"
              },
              {
                "name": "toAsset",
                "value": "",
                "type": "query"
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Query for all convertible token pairs and the tokens' respective upper/lower limits."
        },
        {
          "info": {
            "name": "Send quote request",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.binance.com/sapi/v1/convert/getQuote",
            "params": [
              {
                "name": "fromAsset",
                "value": "",
                "type": "query"
              },
              {
                "name": "toAsset",
                "value": "",
                "type": "query"
              },
              {
                "name": "fromAmount",
                "value": "",
                "type": "query",
                "description": "Amount to convert from. Either fromAmount or toAmount required."
              },
              {
                "name": "toAmount",
                "value": "",
                "type": "query",
                "description": "Amount to convert to. Either fromAmount or toAmount required."
              },
              {
                "name": "walletType",
                "value": "",
                "type": "query",
                "description": "SPOT or FUNDING."
              },
              {
                "name": "validTime",
                "value": "",
                "type": "query",
                "description": "Quote validity period in seconds. 10s, 30s, or 120s."
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Request a quote for asset conversion. The quote is valid for a limited time."
        },
        {
          "info": {
            "name": "Accept quote",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.binance.com/sapi/v1/convert/acceptQuote",
            "params": [
              {
                "name": "quoteId",
                "value": "",
                "type": "query",
                "description": "Quote ID from the quote request."
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Accept a previously requested quote to execute the conversion."
        },
        {
          "info": {
            "name": "Order status",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.binance.com/sapi/v1/convert/orderStatus",
            "params": [
              {
                "name": "orderId",
                "value": "",
                "type": "query"
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Query conversion order status."
        },
        {
          "info": {
            "name": "Get convert trade history",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.binance.com/sapi/v1/convert/tradeFlow",
            "params": [
              {
                "name": "startTime",
                "value": "",
                "type": "query"
              },
              {
                "name": "endTime",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Query conversion trade history."
        }
      ]
    }
  ],
  "bundled": true
}