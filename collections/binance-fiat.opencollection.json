{
  "opencollection": "1.0.0",
  "info": {
    "name": "Binance Fiat API",
    "version": "1"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "X-MBX-APIKEY",
      "value": "{{X-MBX-APIKEY}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Fiat",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get fiat deposit/withdraw history",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.binance.com/sapi/v1/fiat/orders",
            "params": [
              {
                "name": "transactionType",
                "value": "",
                "type": "query",
                "description": "0 for deposit, 1 for withdraw."
              },
              {
                "name": "beginTime",
                "value": "",
                "type": "query"
              },
              {
                "name": "endTime",
                "value": "",
                "type": "query"
              },
              {
                "name": "page",
                "value": "",
                "type": "query"
              },
              {
                "name": "rows",
                "value": "",
                "type": "query",
                "description": "Number of rows. Default 100, max 500."
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Get fiat deposit or withdrawal order history."
        },
        {
          "info": {
            "name": "Get fiat payments history",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.binance.com/sapi/v1/fiat/payments",
            "params": [
              {
                "name": "transactionType",
                "value": "",
                "type": "query",
                "description": "0 for buy, 1 for sell."
              },
              {
                "name": "beginTime",
                "value": "",
                "type": "query"
              },
              {
                "name": "endTime",
                "value": "",
                "type": "query"
              },
              {
                "name": "page",
                "value": "",
                "type": "query"
              },
              {
                "name": "rows",
                "value": "",
                "type": "query"
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Get fiat-to-crypto and crypto-to-fiat payment history."
        }
      ]
    }
  ],
  "bundled": true
}