          "http": {
            "method": "GET",
            "url": "https://api.binance.com/sapi/v1/capital/config/getall",
            "params": [
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Get information of all coins available for deposit and withdrawal, including networks and fee details."
        },
        {
          "info": {
            "name": "Dust transfer",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.binance.com/sapi/v1/asset/dust",
            "params": [
              {
                "name": "asset",
                "value": "",
                "type": "query",
                "description": "Assets to convert, separated by comma."
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Convert dust (small balance assets) to BNB."
        },
        {
          "info": {
            "name": "Asset dividend record",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.binance.com/sapi/v1/asset/assetDividend",
            "params": [
              {
                "name": "asset",
                "value": "",
                "type": "query"
              },
              {
                "name": "startTime",
                "value": "",
                "type": "query"
              },
              {
                "name": "endTime",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Query asset dividend record."
        },
        {
          "info": {
            "name": "Query user universal transfer history",
            "type": "http"
