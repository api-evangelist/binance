        {
          "info": {
            "name": "Position information",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://dapi.binance.com/dapi/v1/positionRisk",
            "params": [
              {
                "name": "symbol",
                "value": "",
                "type": "query"
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
