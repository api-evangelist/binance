    },
    {
      "info": {
        "name": "User Data Stream",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Start user data stream",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://dapi.binance.com/dapi/v1/listenKey",
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Start a new COIN-M futures user data stream."
        },
        {
          "info": {
            "name": "Keepalive user data stream",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://dapi.binance.com/dapi/v1/listenKey",
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Keepalive a COIN-M futures user data stream."
        },
        {
          "info": {
            "name": "Close user data stream",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://dapi.binance.com/dapi/v1/listenKey",
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Close a COIN-M futures user data stream."
        }
