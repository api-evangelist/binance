        {
          "info": {
            "name": "New order",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://dapi.binance.com/dapi/v1/order",
            "params": [
              {
                "name": "symbol",
                "value": "",
                "type": "query"
              },
              {
                "name": "side",
                "value": "",
                "type": "query"
              },
              {
                "name": "positionSide",
                "value": "",
                "type": "query"
              },
              {
                "name": "type",
                "value": "",
                "type": "query"
              },
              {
                "name": "timeInForce",
                "value": "",
                "type": "query"
              },
              {
                "name": "quantity",
                "value": "",
                "type": "query"
              },
              {
                "name": "reduceOnly",
                "value": "",
                "type": "query"
              },
              {
                "name": "price",
                "value": "",
                "type": "query"
              },
              {
                "name": "newClientOrderId",
                "value": "",
                "type": "query"
              },
              {
                "name": "stopPrice",
                "value": "",
                "type": "query"
              },
              {
                "name": "activationPrice",
                "value": "",
                "type": "query"
              },
              {
                "name": "callbackRate",
                "value": "",
                "type": "query"
              },
              {
                "name": "workingType",
                "value": "",
                "type": "query"
              },
              {
                "name": "newOrderRespType",
                "value": "",
                "type": "query"
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Send in a new COIN-M futures order."
        },
        {
          "info": {
            "name": "Cancel order",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://dapi.binance.com/dapi/v1/order",
            "params": [
              {
                "name": "symbol",
                "value": "",
                "type": "query"
              },
              {
                "name": "orderId",
                "value": "",
                "type": "query"
              },
              {
                "name": "origClientOrderId",
                "value": "",
                "type": "query"
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Cancel an active COIN-M futures order."
        },
        {
          "info": {
            "name": "Current all open orders",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://dapi.binance.com/dapi/v1/openOrders",
            "params": [
              {
                "name": "symbol",
                "value": "",
                "type": "query"
              },
              {
                "name": "recvWindow",
                "value": "",
                "type": "query"
              },
              {
                "name": "timestamp",
                "value": "",
                "type": "query"
              },
              {
                "name": "signature",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "apikey",
              "key": "X-MBX-APIKEY",
              "value": "{{X-MBX-APIKEY}}",
              "placement": "header"
            }
          },
          "docs": "Get all open COIN-M futures orders."
        }
      ]
    },
    {
